# DDEV web-container environment — copy this file to .ddev/.env.web and fill in.
#
# .ddev/.env.web is gitignored; never commit real credentials. After editing it,
# run `ddev restart` for the values to take effect inside the container.
#
# Used by `drush dq:static --deploy` (Netlify):
#   NETLIFY_AUTH_TOKEN  Personal access token — https://app.netlify.com/user/applications
#   NETLIFY_SITE_ID     Optional; pin a specific site instead of the linked one
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
