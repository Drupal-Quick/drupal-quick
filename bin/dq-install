#!/usr/bin/env php
<?php

/**
 * dq-install: Step 2 of the drupalquick workflow.
 *
 * Full workflow:
 *   1. composer exec dq-init    — creates config.dq.yml
 *   2. composer exec dq-install — THIS SCRIPT
 *   3. drush dq:scaffold        — installs Drupal and builds the site
 *
 * Reads config.dq.yml and resolves each recipe against the registry
 * (templates/recipe-registry.json). Registry entries come in two kinds:
 *
 *   bundled  — The recipe ships inside this package (e.g. recipes/blog/).
 *              No Composer action needed; dq:scaffold resolves the path
 *              directly from the vendor directory at runtime.
 *
 *   external — The recipe is a standalone Composer package on GitHub.
 *              This script registers its VCS repository in the project's
 *              composer.json and runs `composer require` to install it.
 *
 * Core and contrib recipe paths (e.g. "core/recipes/standard") are not in
 * the registry and require no Composer action — they ship with Drupal core.
 *
 * Also ensures drupal/core-recipe-unpack is present as a root-level project
 * dependency. Composer only activates plugins declared at the root level, so
 * this package cannot declare it on the project's behalf — it must live in
 * the consumer's own composer.json.
 */

$packageRoot = dirname(__DIR__);
$projectRoot = getcwd();

// Load the project autoloader so Symfony YAML is available.
$autoload = $projectRoot . '/vendor/autoload.php';
if (!file_exists($autoload)) {
    die("❌ vendor/autoload.php not found. Run `composer install` first.\n");
}
require_once $autoload;

use Symfony\Component\Yaml\Yaml;
use Symfony\Component\Yaml\Exception\ParseException;

// ------------------------------------------------------------------ Config

$configFile = $projectRoot . '/config.dq.yml';
if (!file_exists($configFile)) {
    die("❌ config.dq.yml not found. Run `composer exec dq-init` first.\n");
}

try {
    $config = Yaml::parseFile($configFile);
} catch (ParseException $e) {
    die("❌ Could not parse config.dq.yml: {$e->getMessage()}\n");
}

$recipes = $config['recipes'] ?? [];
if (empty($recipes)) {
    echo "ℹ️  No recipes listed in config.dq.yml. Nothing to install.\n";
    echo "   Run `drush dq:scaffold` when ready.\n";
    exit(0);
}

// ------------------------------------------------------------------ Registry
// The registry maps short recipe keys to their package metadata. Each entry
// declares: package name, VCS url, install path, whether it is bundled inside
// drupal-quick, and whether it ships theme-assets. Entries absent from the
// registry are treated as literal paths (e.g. core/recipes/standard) and need
// no Composer action here — dq:scaffold passes them directly to drush recipe.

$registryFile = $packageRoot . '/templates/recipe-registry.json';
if (!file_exists($registryFile)) {
    die("❌ recipe-registry.json missing from drupalquick package.\n");
}
$registry = json_decode(file_get_contents($registryFile), true);

// ------------------------------------------------------------------ Project composer.json

$composerFile = $projectRoot . '/composer.json';
if (!file_exists($composerFile)) {
    die("❌ composer.json not found in project root.\n");
}
$composer = json_decode(file_get_contents($composerFile), true);

// ------------------------------------------------------------------ Peer deps

// drupal/core-recipe-unpack must be a root-level dependency of the consumer
// project for recipe Composer dependencies to be unpacked correctly.
$peerPackage = 'drupal/core-recipe-unpack';
$rootRequire = array_merge(
    array_keys($composer['require'] ?? []),
    array_keys($composer['require-dev'] ?? [])
);
if (!in_array($peerPackage, $rootRequire, true)) {
    echo "📎 Adding {$peerPackage} to project composer.json...\n";
    $composer['require'][$peerPackage] = '^1.0';
    file_put_contents(
        $composerFile,
        json_encode($composer, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n"
    );
    passthru("composer require {$peerPackage}", $exitCode);
    if ($exitCode !== 0) {
        echo "❌ Failed to install {$peerPackage}. Recipes with Composer dependencies may not unpack correctly.\n";
    }
    // Re-read composer after require rewrites it.
    $composer = json_decode(file_get_contents($composerFile), true);
}

// ------------------------------------------------------------------ Resolve

$toRequire = [];

foreach ($recipes as $recipe) {
    if (!isset($registry[$recipe])) {
        // Not a drupalquick-managed recipe — no action needed here.
        continue;
    }

    $info = $registry[$recipe];

    // Bundled recipes ship inside this package at recipes/{name}/ and are
    // resolved to an absolute vendor path by dq:scaffold at runtime. No
    // Composer action is needed here.
    //
    // TODO (long-term): When a bundled recipe is extracted into its own package
    // (e.g. drupal-quick/recipe-blog at https://github.com/Drupal-Quick/recipe-blog),
    // remove "bundled": true from its registry entry and set "url" to the real
    // GitHub URL. This block will then be skipped and the recipe will be installed
    // as an external package via the VCS + require logic below.
    if (!empty($info['bundled'])) {
        echo "ℹ️  '{$recipe}' is bundled with drupal-quick — skipping install.\n";
        continue;
    }

    $package = $info['package'];
    $url     = $info['url'];

    // Add VCS repository entry if it is not already present.
    $repos   = $composer['repositories'] ?? [];
    $exists  = false;
    foreach ($repos as $repo) {
        if (($repo['url'] ?? '') === $url) {
            $exists = true;
            break;
        }
    }

    if (!$exists) {
        $composer['repositories'][] = ['type' => 'vcs', 'url' => $url];
        echo "📎 Registered VCS repository for {$package}\n";
    } else {
        echo "ℹ️  Repository for {$package} already registered.\n";
    }

    $toRequire[] = $package;
}

// Write back the updated composer.json before running require so Composer
// can find the newly added VCS repositories.
if (!empty($toRequire)) {
    file_put_contents(
        $composerFile,
        json_encode($composer, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n"
    );
}

// ------------------------------------------------------------------ Require

if (empty($toRequire)) {
    echo "ℹ️  No drupalquick-managed recipes to install (core/contrib recipes\n";
    echo "   are already available on disk).\n";
    echo "   Run `drush dq:scaffold` when ready.\n";
    exit(0);
}

foreach ($toRequire as $package) {
    echo "\n📦 Installing {$package}...\n";
    passthru("composer require {$package}", $exitCode);
    if ($exitCode !== 0) {
        echo "❌ `composer require {$package}` failed.\n";
        exit($exitCode);
    }
}

echo "\n✅ Recipe packages installed.\n";
echo "   Run `drush dq:scaffold` to build your site.\n";
