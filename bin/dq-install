#!/usr/bin/env php
<?php

/**
 * dq-install: Step 2 of the drupalquick workflow.
 *
 * Full workflow:
 *   1. composer exec dq-init    — creates config.dq.yml
 *   2. composer exec dq-install — THIS SCRIPT
 *   3. ddev drush dq:scaffold   — installs Drupal and builds the site
 *
 * Reads config.dq.yml and resolves each recipe against the registry
 * (templates/recipe-registry.json). Registry recipes are standalone Composer
 * packages: this script registers each one's VCS repository (unless a local
 * path repo already provides it) and runs `composer require`, after which
 * core-recipe-unpack places the recipe under the project's recipes/ directory.
 *
 * Core and contrib recipe paths (e.g. "core/recipes/standard") are not in
 * the registry and require no Composer action — they ship with Drupal core.
 *
 * Also ensures drupal/core-recipe-unpack is present as a root-level project
 * dependency. Composer only activates plugins declared at the root level, so
 * this package cannot declare it on the project's behalf — it must live in
 * the consumer's own composer.json.
 *
 * After installing, each recipe's user-tunable options (recipe.yml `input:`)
 * are written back into config.dq.yml as a COMMENTED block under that recipe's
 * entry, ready to uncomment. Pass --exclude-options to only list them in the
 * terminal and leave config.dq.yml untouched.
 */

$packageRoot    = dirname(__DIR__);
$projectRoot    = getcwd();
$excludeOptions = in_array('--exclude-options', $argv, true);

// Load the project autoloader so Symfony YAML is available.
$autoload = $projectRoot . '/vendor/autoload.php';
if (!file_exists($autoload)) {
    die("❌ vendor/autoload.php not found. Run `composer install` first.\n");
}
require_once $autoload;

// The injection logic lives in plain classes in this package — required directly
// so they resolve regardless of the consumer autoloader's state.
require_once $packageRoot . '/src/Config/RecipeOptions.php';
require_once $packageRoot . '/src/Config/RecipeBlocks.php';
require_once $packageRoot . '/src/Environment/Comingling.php';

use DrupalQuick\Config\RecipeOptions;
use DrupalQuick\Config\RecipeBlocks;
use DrupalQuick\Environment\Comingling;
use Symfony\Component\Yaml\Yaml;
use Symfony\Component\Yaml\Exception\ParseException;
use Symfony\Component\Process\Process;

// Refuse a host run inside a DDEV project — run `ddev composer exec dq-install`.
if ($guard = Comingling::hostInDdevProjectError($projectRoot, Comingling::env())) {
    fwrite(STDERR, "❌ {$guard}\n");
    exit(1);
}

// Next-step guidance prefixed with `ddev` in a DDEV project (bare otherwise).
$cmd = is_file($projectRoot . '/.ddev/config.yaml') ? 'ddev ' : '';

/**
 * Runs an external command via Symfony Process, streaming its output.
 *
 * Array arguments mean no shell is invoked, so package names and paths cannot
 * be interpreted as shell syntax (no injection, no quoting to get wrong).
 * Returns the exit code.
 */
function run_command(array $command, string $cwd): int {
    $process = new Process($command, $cwd, null, null, null);
    $process->run(function (string $type, string $buffer): void {
        echo $buffer;
    });
    return $process->getExitCode() ?? 1;
}

// The option-line rendering and commented-block injection live in
// DrupalQuick\Config\RecipeOptions (required above) so they are unit-testable;
// see tests/Unit/Config/RecipeOptionsTest.php.

// ------------------------------------------------------------------ Config

$configFile = $projectRoot . '/config.dq.yml';
if (!file_exists($configFile)) {
    die("❌ config.dq.yml not found. Run `composer exec dq-init` first.\n");
}

try {
    $config = Yaml::parseFile($configFile);
} catch (ParseException $e) {
    die("❌ Could not parse config.dq.yml: {$e->getMessage()}\n");
}

$recipes = $config['recipes'] ?? [];
if (empty($recipes)) {
    echo "ℹ️  No recipes listed in config.dq.yml. Nothing to install.\n";
    echo "   Run `{$cmd}drush dq:scaffold` when ready.\n";
    exit(0);
}

// ------------------------------------------------------------------ Registry
// The registry maps short recipe keys to their package metadata: package name,
// VCS url, and a human label. (The unpacked path and whether the recipe ships
// theme-assets are derived at runtime by dq:scaffold.) Entries absent from the
// registry are treated as literal paths (e.g. core/recipes/standard) and need
// no Composer action here — dq:scaffold passes them directly to drush recipe.

$registryFile = $packageRoot . '/templates/recipe-registry.json';
if (!file_exists($registryFile)) {
    die("❌ recipe-registry.json missing from drupalquick package.\n");
}
$registry = json_decode(file_get_contents($registryFile), true);

// ------------------------------------------------------------------ Project composer.json

$composerFile = $projectRoot . '/composer.json';
if (!file_exists($composerFile)) {
    die("❌ composer.json not found in project root.\n");
}
$composer = json_decode(file_get_contents($composerFile), true);

// ------------------------------------------------------------------ Peer deps

// drupal/core-recipe-unpack must be a root-level dependency of the consumer
// project for recipe Composer dependencies to be unpacked correctly.
$peerPackage = 'drupal/core-recipe-unpack';
$rootRequire = array_merge(
    array_keys($composer['require'] ?? []),
    array_keys($composer['require-dev'] ?? [])
);
if (!in_array($peerPackage, $rootRequire, true)) {
    echo "📎 Adding {$peerPackage} to project composer.json...\n";
    // core-recipe-unpack version-syncs with Drupal core (11.2+); the early
    // standalone 1.x alphas are gone.
    $composer['require'][$peerPackage] = '^11.2';
    file_put_contents(
        $composerFile,
        json_encode($composer, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n"
    );
    $exitCode = run_command(['composer', 'require', $peerPackage], $projectRoot);
    if ($exitCode !== 0) {
        echo "❌ Failed to install {$peerPackage}. Recipes with Composer dependencies may not unpack correctly.\n";
    }
    // Re-read composer after require rewrites it.
    $composer = json_decode(file_get_contents($composerFile), true);
}

// ------------------------------------------------------------------ Resolve

$toRequire = [];

foreach ($recipes as $recipe) {
    // A recipe entry is a registry key, {name, options} (options map to the
    // recipe's native inputs — consumed by dq:scaffold, not here), an inline
    // package spec ({package, url, options?}), or a core/contrib path string
    // (no Composer action).
    if (is_array($recipe) && isset($recipe['name'])) {
        $recipe = $recipe['name'];
    }
    if (is_array($recipe)) {
        $package = $recipe['package'] ?? null;
        $url     = $recipe['url'] ?? '';
        if (!$package) {
            continue;
        }
    } elseif (isset($registry[$recipe])) {
        $package = $registry[$recipe]['package'];
        $url     = $registry[$recipe]['url'] ?? '';
    } else {
        continue;
    }
    $short = ($pos = strpos($package, '/')) !== false ? substr($package, $pos + 1) : $package;

    // Register the package's VCS repository unless one already provides it — by
    // matching url, or a local path repo whose directory is named for the
    // package (used during local development before the package is published).
    $repos    = $composer['repositories'] ?? [];
    $provided = false;
    foreach ($repos as $repo) {
        $repoUrl = $repo['url'] ?? '';
        if (($url !== '' && $repoUrl === $url) || basename(rtrim($repoUrl, '/')) === $short) {
            $provided = true;
            break;
        }
    }

    if ($provided) {
        echo "ℹ️  Repository for {$package} already configured.\n";
    } elseif ($url !== '') {
        $composer['repositories'][] = ['type' => 'vcs', 'url' => $url];
        echo "📎 Registered VCS repository for {$package}\n";
    }

    $toRequire[] = $package;
}

// Write back the updated composer.json before running require so Composer
// can find the newly added VCS repositories.
if (!empty($toRequire)) {
    file_put_contents(
        $composerFile,
        json_encode($composer, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES) . "\n"
    );
}

// ------------------------------------------------------------------ Require

if (empty($toRequire)) {
    echo "ℹ️  No drupalquick-managed recipes to install (core/contrib recipes\n";
    echo "   are already available on disk).\n";
    echo "   Run `{$cmd}drush dq:scaffold` when ready.\n";
    exit(0);
}

foreach ($toRequire as $package) {
    echo "\n📦 Installing {$package}...\n";
    $exitCode = run_command(['composer', 'require', $package], $projectRoot);
    if ($exitCode !== 0) {
        echo "❌ `composer require {$package}` failed.\n";
        exit($exitCode);
    }
}

echo "\n✅ Recipe packages installed.\n";

// --------------------------------------------------------------- Options + Block catalog
// Two write-back operations on config.dq.yml; we do them in a single read/write
// pass to avoid multiple file round-trips.
//
// Options: each managed recipe may declare user-tunable inputs (recipe.yml
//   `input:`). Default: write them as a commented block under the recipe entry.
//   --exclude-options: print to terminal only, don't touch the file.
//
// Block catalog: each registry recipe may advertise placeable blocks in its
//   composer.json extra.dq.recipe.blocks. Always written as a commented
//   `# ── Available recipe blocks` section so the user knows what keys to use
//   in homepage: > blocks: (and future placement targets).

// Collect options from unpacked recipe.yml files.
$recipeOptions = [];
foreach ($recipes as $recipe) {
    if (is_array($recipe) && isset($recipe['name'])) {
        $key = $recipe['name'];
    } elseif (is_string($recipe)) {
        $key = $recipe;
    } else {
        continue;
    }
    if (!isset($registry[$key]['package'])) {
        continue;
    }
    $pkg        = $registry[$key]['package'];
    $short      = ($pos = strpos($pkg, '/')) !== false ? substr($pkg, $pos + 1) : $pkg;
    $recipeFile = $projectRoot . '/recipes/' . $short . '/recipe.yml';
    if (!file_exists($recipeFile)) {
        continue;
    }
    try {
        $recipeData = Yaml::parseFile($recipeFile);
    } catch (ParseException) {
        continue;
    }
    if (!empty($recipeData['input'])) {
        $recipeOptions[$key] = $recipeData['input'];
    }
}

// Collect blocks from the registry for all installed registry recipes.
$recipeBlocks = [];
foreach ($recipes as $recipe) {
    if (is_array($recipe) && isset($recipe['name'])) {
        $key = $recipe['name'];
    } elseif (is_string($recipe)) {
        $key = $recipe;
    } else {
        continue;
    }
    if (!isset($registry[$key]['blocks'])) {
        continue;
    }
    foreach ($registry[$key]['blocks'] as $blockKey => $blockMeta) {
        $recipeBlocks["{$key}/{$blockKey}"] = [
            'label'  => $blockMeta['label'] ?? $blockKey,
            'plugin' => $blockMeta['plugin'] ?? '',
        ];
    }
}

// Print options to terminal when --exclude-options is set.
if (!empty($recipeOptions) && $excludeOptions) {
    echo "\nℹ️  Optional recipe settings — set under `options:` on the recipe's entry\n";
    echo "   in config.dq.yml (defaults apply when unset):\n";
    foreach ($recipeOptions as $key => $inputs) {
        echo "   {$key}:\n";
        foreach ($inputs as $name => $def) {
            $description = $def['description'] ?? '';
            $default     = $def['default']['value'] ?? null;
            $defaultText = is_scalar($default) ? ' [default: ' . var_export($default, true) . ']' : '';
            echo "     - {$name}: {$description}{$defaultText}\n";
        }
    }
}

// Single read → inject options → inject block catalog → single write.
$needsOptionWrite = !empty($recipeOptions) && !$excludeOptions;
$needsBlockWrite  = !empty($recipeBlocks);

if ($needsOptionWrite || $needsBlockWrite) {
    $lines  = explode("\n", file_get_contents($configFile));
    $before = $lines;

    $injectedOptions = [];
    if ($needsOptionWrite) {
        foreach ($recipeOptions as $key => $inputs) {
            $prev  = $lines;
            $lines = RecipeOptions::injectCommented($lines, $key, RecipeOptions::activeLines($inputs));
            if ($lines !== $prev) {
                $injectedOptions[] = $key;
            }
        }
    }

    if ($needsBlockWrite) {
        $lines = RecipeBlocks::injectCatalog($lines, $recipeBlocks);
    }

    if ($lines !== $before) {
        file_put_contents($configFile, implode("\n", $lines));
        if ($injectedOptions) {
            echo "\nℹ️  Wrote commented recipe options into config.dq.yml for: " . implode(', ', $injectedOptions) . ".\n";
            echo "   Uncomment (remove the leading `# `) under each recipe to override its defaults.\n";
        }
        if ($needsBlockWrite) {
            echo "\nℹ️  Wrote recipe block catalog into config.dq.yml.\n";
            echo "   Uncomment the homepage: section (remove `# `) to compose the front page.\n";
        }
    }
}

echo "\n   Run `{$cmd}drush dq:scaffold` to build your site.\n";
