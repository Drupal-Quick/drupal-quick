#!/usr/bin/env php
<?php

/**
 * dq-init: Step 1 of the drupalquick workflow.
 *
 * Full workflow:
 *   1. composer exec dq-init [--interactive] [--ddev]  ← this script
 *      Delivers config.dq.yml to the project root.
 *   2. composer exec dq-install
 *      Installs any drupalquick-managed recipe packages via Composer.
 *   3. drush dq:scaffold
 *      Installs Drupal, generates the theme, applies recipes, builds assets.
 *
 * The sole output of this script is config.dq.yml — a single YAML file the
 * developer reviews and owns before anything is installed. No Drupal code is
 * touched here; dq:scaffold is what actually builds the site.
 *
 * Without flags — copies the template and exits. The user edits the file
 * then runs `composer exec dq-install`.
 *
 * With --interactive — walks the user through site, theme, and recipe
 * choices via CLI prompts and writes a pre-filled config.dq.yml.
 *
 * With --ddev — copies the drupalquick DDEV local config template into the
 * project's .ddev/ directory if one exists. Can be combined with either of
 * the above modes.
 */

$packageRoot = dirname(__DIR__);
$projectRoot = getcwd();
$destination = $projectRoot . '/config.dq.yml';
$interactive = in_array('--interactive', $argv, true);
$ddev        = in_array('--ddev', $argv, true);

// ------------------------------------------------------------------ Helpers

function ask(string $question, string $default = ''): string {
    $hint = $default !== '' ? " [{$default}]" : '';
    echo "{$question}{$hint}: ";
    $answer = trim(fgets(STDIN));
    return $answer !== '' ? $answer : $default;
}

function choose(string $question, array $options, string $default = ''): string {
    echo "\n{$question}\n";
    foreach ($options as $i => $label) {
        $marker = $label === $default ? ' (default)' : '';
        echo '  ' . ($i + 1) . ". {$label}{$marker}\n";
    }
    $defaultPos = array_search($default, $options, true);
    $defaultNum = $defaultPos !== false ? $defaultPos + 1 : 1;
    echo "Choice [{$defaultNum}]: ";
    $input = trim(fgets(STDIN));
    $idx   = $input !== '' ? (int)$input - 1 : ($defaultPos !== false ? $defaultPos : 0);
    return $options[$idx] ?? $options[0];
}

function chooseMany(string $question, array $options): array {
    echo "\n{$question}\n";
    echo "(Enter comma-separated numbers, e.g. 1,3 — or press Enter to skip)\n";
    foreach ($options as $i => $info) {
        echo '  ' . ($i + 1) . ". {$info['label']}\n";
    }
    echo 'Choice: ';
    $input = trim(fgets(STDIN));
    if ($input === '') {
        return [];
    }
    $chosen = [];
    foreach (explode(',', $input) as $num) {
        $idx = (int)trim($num) - 1;
        if (isset($options[$idx])) {
            $chosen[] = $options[$idx]['key'];
        }
    }
    return $chosen;
}

// ------------------------------------------------------------------ Non-interactive

if (!$interactive) {
    if (file_exists($destination)) {
        echo "ℹ️  config.dq.yml already exists. Edit it, then run:\n";
        echo "   composer exec dq-install\n";
    } else {
        $source = $packageRoot . '/templates/config.dq.yml';
        if (!copy($source, $destination)) {
            echo "❌ Failed to write config.dq.yml to project root.\n";
            exit(1);
        }
        echo "✅ config.dq.yml created in project root.\n";
        echo "   Edit it to configure your site, then run:\n";
        echo "   composer exec dq-install\n";
    }

    // Handle --ddev regardless of whether config already existed.
    if ($ddev) {
        ddev_copy($packageRoot, $projectRoot);
    }

    exit(0);
}

// ------------------------------------------------------------------ Interactive

echo "\n drupalquick — interactive setup\n";
echo str_repeat('─', 40) . "\n\n";

// Site
echo "--- Site ---\n";
$siteName  = ask('Site name', 'My Drupal Site');
$adminUser = ask('Admin username', 'admin');
$adminPass = ask('Admin password (leave blank to auto-generate a strong one at scaffold time)', '');

// Theme
echo "\n--- Theme ---\n";
$themeMachine = ask('Theme machine name (lowercase, underscores)', 'my_theme');
$themeTitle   = ask('Theme display name', 'My Theme');

// Discover skins from the installed starterkit package: its composer.json
// extra.dq.skins metadata, falling back to scanning its skins/ directory. The
// starterkit ships as drupal-quick/dq_starterkit, installed at
// web/themes/contrib/dq_starterkit.
$starterkitDir = $projectRoot . '/web/themes/contrib/dq_starterkit';
$skins = [];
if (file_exists($starterkitDir . '/composer.json')) {
    $meta  = json_decode(file_get_contents($starterkitDir . '/composer.json'), true) ?: [];
    $skins = $meta['extra']['dq']['skins'] ?? [];
}
if (empty($skins) && is_dir($starterkitDir . '/skins')) {
    foreach (scandir($starterkitDir . '/skins') as $file) {
        if (pathinfo($file, PATHINFO_EXTENSION) === 'css') {
            $skins[] = pathinfo($file, PATHINFO_FILENAME);
        }
    }
}
if (empty($skins)) {
    $skins = ['minimal', 'corporate'];
}
$themeSkin = choose('Design skin', $skins, 'minimal');

// Recipes
// core/recipes/standard is always seeded as the base recipe — it installs the
// standard content types and config that other recipes depend on. Additional
// recipes are sourced from the registry (templates/recipe-registry.json), which
// lists both bundled recipes (shipped inside this package) and future external
// packages. Core/* and contrib/* paths can be added manually to config.dq.yml
// after generation if needed.
$registryFile = $packageRoot . '/templates/recipe-registry.json';
$registry     = file_exists($registryFile)
    ? json_decode(file_get_contents($registryFile), true)
    : [];

$recipeLines = ['  - "core/recipes/standard"'];

if (!empty($registry)) {
    $options = [];
    foreach ($registry as $key => $info) {
        $options[] = ['key' => $key, 'label' => $info['label'] ?? $key];
    }
    $chosen = chooseMany('Which drupalquick recipes would you like to include?', $options);
    foreach ($chosen as $key) {
        $recipeLines[] = "  - \"{$key}\"";
    }
}

$recipesBlock = implode("\n", $recipeLines);

// Only write admin_pass when the user supplied one — otherwise leave it out so
// dq:scaffold generates a strong password and shows it once, keeping a secret
// off disk by default.
$adminPassLine = $adminPass !== '' ? "\n  admin_pass: \"{$adminPass}\"" : '';

// Write config
$yaml = <<<YAML
site:
  name: "{$siteName}"
  admin_user: "{$adminUser}"{$adminPassLine}

theme:
  machine_name: "{$themeMachine}"
  title: "{$themeTitle}"
  style: "{$themeSkin}"

recipes:
{$recipesBlock}

parameters:
  theme_design:
    primary_color: "#10b981"
    secondary_color: "#1e3a8a"
    font_family: "'Inter', sans-serif"
  recipe_config:
    "system.site":
      slogan: "Scaffolded quickly, maintained sustainably."
YAML;

if (file_put_contents($destination, $yaml) === false) {
    echo "❌ Failed to write config.dq.yml.\n";
    exit(1);
}

echo "\n✅ config.dq.yml created.\n";
echo "   Review it, make any edits, then run:\n";
echo "   composer exec dq-install\n";

if ($ddev) {
    ddev_copy($packageRoot, $projectRoot);
}

echo "\n";
exit(0);

// ------------------------------------------------------------------ DDEV helper

function ddev_copy(string $packageRoot, string $projectRoot): void {
    $ddevDir = $projectRoot . '/.ddev';
    $src     = $packageRoot . '/templates/ddev/config.local.yaml';

    if (!is_dir($ddevDir)) {
        echo "ℹ️  --ddev passed but no .ddev directory found in project root. Skipping.\n";
        return;
    }

    if (!file_exists($src)) {
        echo "❌ DDEV template missing from package at templates/ddev/config.local.yaml.\n";
        return;
    }

    $dest = $ddevDir . '/config.local.yaml';
    if (copy($src, $dest)) {
        echo "✅ DDEV local config copied to .ddev/config.local.yaml\n";
    } else {
        echo "❌ Failed to copy DDEV config to {$dest}\n";
    }

    // Deliver the credentials example for `drush dq:static --deploy`. The real
    // .ddev/.env.web (which DDEV loads into the web container) holds secrets and
    // must stay out of git, so we copy a keys-only example and gitignore the
    // real file rather than ever shipping a value placeholder.
    $envExampleSrc = $packageRoot . '/templates/ddev/.env.web.example';
    if (file_exists($envExampleSrc)) {
        if (copy($envExampleSrc, $ddevDir . '/.env.web.example')) {
            echo "✅ DDEV deploy-credentials example copied to .ddev/.env.web.example\n";
        }
        ddev_gitignore_env($projectRoot);
    }
}

/**
 * Ensures the project's .gitignore excludes the secret .ddev/.env.web file.
 *
 * DDEV's own auto-managed .ddev/.gitignore does not cover this custom file, so
 * we add it to the project root .gitignore. The keys-only .env.web.example is
 * intentionally left tracked.
 */
function ddev_gitignore_env(string $projectRoot): void {
    $gitignore = $projectRoot . '/.gitignore';
    $entry     = '.ddev/.env.web';
    $existing  = file_exists($gitignore) ? file_get_contents($gitignore) : '';

    if (preg_match('/^\s*' . preg_quote($entry, '/') . '\s*$/m', $existing)) {
        return;
    }

    $prefix = ($existing !== '' && substr($existing, -1) !== "\n") ? "\n" : '';
    $block  = "{$prefix}\n# drupalquick: deploy credentials (drush dq:static --deploy)\n{$entry}\n";
    if (file_put_contents($gitignore, $block, FILE_APPEND) !== FALSE) {
        echo "✅ Added {$entry} to .gitignore\n";
    }
}
